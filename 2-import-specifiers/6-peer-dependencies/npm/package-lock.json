{
  "name": "npm-peer-dependencies-example",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "npm-peer-dependencies-example",
      "workspaces": [
        "lib",
        "app-provided",
        "app-missing"
      ]
    },
    "app-missing": {
      "dependencies": {
        "lib": "*"
      }
    },
    "app-provided": {
      "dependencies": {
        "is-number": "^7.0.0",
        "lib": "*"
      }
    },
    "lib": {
      "peerDependencies": {
        "is-number": "^7.0.0"
      }
    },
    "node_modules/app-missing": {
      "resolved": "app-missing",
      "link": true
    },
    "node_modules/app-provided": {
      "resolved": "app-provided",
      "link": true
    },
    "node_modules/is-number": {
      "version": "7.0.0",
      "resolved": "https://registry.npmjs.org/is-number/-/is-number-7.0.0.tgz",
      "integrity": "sha512-41Cifkg6e8TylSpdtTpeLVMqvSBEVzTttHvERD741+pnZ8ANv0004MRL43QKPDlK9cGvNp6NZWZUBlbGXYxxng==",
      "license": "MIT",
      "engines": {
        "node": ">=0.12.0"
      }
    },
    "node_modules/lib": {
      "resolved": "lib",
      "link": true
    }
  }
}
